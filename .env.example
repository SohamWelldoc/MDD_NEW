# ============================================
# Confluence Source
# ============================================
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_USERNAME=you@example.com
CONFLUENCE_API_TOKEN=replace-me

# ============================================
# JSONL vector store
# ============================================
# Confluence chunks and embeddings are stored under:
#   ARTIFACT_BASE_DIR/<product>/<release>/confluence/
COLLECTION_NAME=hld_pipeline_pages
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ============================================
# LLM Provider — MDD_NEW defaults to Azure AI Foundry (Llama-3.3-70B-Instruct)
# Options: 'azure_ai_foundry' (default) | 'aks'
# ============================================
LLM_PROVIDER=azure_ai_foundry

# Azure AI Foundry
AZURE_AI_FOUNDRY_URL=https://wdllmazureai.services.ai.azure.com/openai/v1/
AZURE_AI_FOUNDRY_API_KEY=replace-me
AZURE_AI_FOUNDRY_MODEL_NAME=Llama-3.3-70B-Instruct

# AKS Mistral (fallback / optional)
AKS_LLM_URL=http://10.104.1.10/mistral/v1
AKS_LLM_API_KEY=not-needed
AKS_MODEL_NAME=mistralai/Devstral-Small-2507

# ============================================
# API
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# Product/release artifact output
# ============================================
ARTIFACT_BASE_DIR=./artifacts
PROJECT=als
RELEASE=3.0_release

# ============================================
# SOP-036 template (docx reference for future exports)
# ============================================
MDD_TEMPLATE_PATH="./SOP-036_Rev_04_attachments_Attachment 2 MDD template_SOP036.docx"
DOCX_REFERENCE_PATH=
HLD_LOGO_PATH=./backend/assets/welldoc_logo.png
HLD_DOCUMENT_TITLE=
HLD_DOCUMENT_ID=
MERMAID_CLI_PATH=./tools/mermaid/node_modules/.bin/mmdc.cmd
MERMAID_PUPPETEER_CONFIG=./tools/puppeteer-config.json
KEEP_DOCX_ASSETS=false

# ============================================
# Code graph (static monolith Graphify export)
# ============================================
# Shared across all features. Per-feature scope comes from contract_*.json.
GRAPH_PATH=../graph.json

# ============================================
# Chunker (reused from confluence-knowledge-chatbot)
# ============================================
CHUNKER_VERSION=v1
CHUNK_SIZE=2500
CHUNK_OVERLAP=250
USE_SENTENCE_SPLITTING=true
USE_TOKEN_COUNTING=false
USE_ADAPTIVE_SIZING=true
USE_SMART_OVERLAP=true
PRESERVE_TABLE_HEADERS=true
PRESERVE_CODE_STRUCTURE=true
ADD_LINK_CONTEXT=true
ADD_METADATA_SCORING=true
ADD_HIERARCHICAL_CONTEXT=true

# ============================================
# Retrieval v2.1 enhancements
# ============================================
ENABLE_QUERY_REFORMULATION=true
ENABLE_HYDE=true
ENABLE_DYNAMIC_WEIGHTS=true
ENABLE_CONTEXT_ENHANCEMENT=true
ENABLE_COT_PROMPTING=true
ENABLE_CONVERSATIONAL_REWRITE=true

# ============================================
# Session storage
# ============================================
ENABLE_PERSISTENT_SESSIONS=true
SESSION_STORAGE_PATH=./session_storage
INGESTION_JOB_TTL_HOURS=48
CHAT_SESSION_TTL_HOURS=24
